# ==========================================
# SecureKYC Demo App - Environment Variables
# ==========================================

# PostgreSQL via Supabase or local (optional — falls back to local JSON DB)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Supabase Storage (optional — falls back to public/uploads/)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# JWT secret (change this to a strong random string in production)
JWT_SECRET="securekyc-demo-change-me-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Provider Configuration
# ==========================================
# Options: 'mock' | 'decentro' | 'surepass'
AADHAAR_PROVIDER=mock
PAN_PROVIDER=mock

# Decentro (for PAN verification)
DECENTRO_CLIENT_ID=
DECENTRO_CLIENT_SECRET=
DECENTRO_BASE_URL=https://in.staging.decentro.tech

# Surepass (for Aadhaar OTP verification)
SUREPASS_API_KEY=
SUREPASS_BASE_URL=https://sandbox.surepass.io
